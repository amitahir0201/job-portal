# Server
PORT=5000
MONGO_URI=mongodb://localhost:27017/jobportal
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL used in reset emails
FRONTEND_URL=http://localhost:3000

# Mail (SMTP) settings - use real provider credentials in production
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM_NAME=JobHub Support
EMAIL_FROM_EMAIL=no-reply@jobhub.example
SUPPORT_EMAIL=support@jobhub.example
